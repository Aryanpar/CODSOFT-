<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- ── Checkbox ── -->
        <CheckBox
            android:id="@+id/taskCheck"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:button="@null"
            android:background="@drawable/checkbox_custom"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/taskTitle"
            app:layout_constraintBottom_toBottomOf="@+id/taskTitle"/>

        <!-- ── Task Title ── -->
        <TextView
            android:id="@+id/taskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:lineSpacingExtra="2dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@+id/taskCheck"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- ── Description (shown only if non-empty) ── -->
        <TextView
            android:id="@+id/taskDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:lineSpacingExtra="1dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="3dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@+id/taskTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/taskTitle"/>

        <!-- ── Thin divider ── -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/colorStroke"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/taskDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Priority badge ── -->
        <TextView
            android:id="@+id/taskPriority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- ── Due date ── -->
        <TextView
            android:id="@+id/taskDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@+id/taskPriority"
            app:layout_constraintEnd_toStartOf="@+id/editBtn"
            app:layout_constraintTop_toTopOf="@+id/taskPriority"
            app:layout_constraintBottom_toBottomOf="@+id/taskPriority"/>

        <!-- ── Edit icon button ── -->
        <ImageButton
            android:id="@+id/editBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_edit"
            android:background="@drawable/bg_button_edit"
            android:scaleType="centerInside"
            android:padding="7dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Edit"
            app:layout_constraintEnd_toStartOf="@+id/deleteBtn"
            app:layout_constraintTop_toTopOf="@+id/taskPriority"
            app:layout_constraintBottom_toBottomOf="@+id/taskPriority"/>

        <!-- ── Delete icon button ── -->
        <ImageButton
            android:id="@+id/deleteBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/bg_button_delete"
            android:scaleType="centerInside"
            android:padding="7dp"
            android:contentDescription="Delete"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/taskPriority"
            app:layout_constraintBottom_toBottomOf="@+id/taskPriority"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>